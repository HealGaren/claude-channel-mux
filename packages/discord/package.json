{
  "name": "@claude-channel-mux/discord",
  "version": "0.1.0-alpha.1",
  "description": "Discord adapter, daemon, and plugin for claude-channel-mux",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "HealGaren",
    "url": "https://github.com/HealGaren"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HealGaren/claude-channel-mux.git",
    "directory": "packages/discord"
  },
  "keywords": [
    "claude",
    "claude-code",
    "discord",
    "mcp",
    "channel"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "channel-mux-daemon": "./dist/daemon.mjs",
    "channel-mux-plugin": "./dist/plugin.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "skills",
    ".claude-plugin"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "tsx src/daemon.ts",
    "dev": "tsx --watch src/daemon.ts"
  },
  "dependencies": {
    "@claude-channel-mux/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "discord.js": "^14.14.0"
  }
}
