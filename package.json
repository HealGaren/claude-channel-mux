{
  "name": "claude-channel-mux",
  "version": "0.1.0",
  "description": "Multiplex Claude Code channel sessions through a single Discord bot",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HealGaren/claude-channel-mux.git"
  },
  "author": {
    "name": "HealGaren",
    "url": "https://github.com/HealGaren"
  },
  "keywords": [
    "claude",
    "claude-code",
    "discord",
    "mcp",
    "multiplexer",
    "channel"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "files": [
    "dist",
    "skills",
    ".claude-plugin"
  ],
  "exports": {
    "./types": {
      "import": "./dist/types.mjs",
      "types": "./dist/types.d.mts"
    },
    "./ipc": {
      "import": "./dist/ipc.mjs",
      "types": "./dist/ipc.d.mts"
    },
    "./adapters/discord": {
      "import": "./dist/adapters-discord.mjs",
      "types": "./dist/adapters-discord.d.mts"
    }
  },
  "bin": {
    "channel-mux": "./dist/cli.mjs",
    "channel-mux-plugin": "./dist/plugin.mjs"
  },
  "scripts": {
    "start": "tsx src/daemon.ts",
    "dev": "tsx --watch src/daemon.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "discord.js": "^14.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
