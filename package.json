{
  "name": "claude-channel-mux-root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multiplex Claude Code channel sessions through a single Discord bot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HealGaren/claude-channel-mux.git"
  },
  "author": {
    "name": "HealGaren",
    "url": "https://github.com/HealGaren"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm --filter @claude-channel-mux/core run build && pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:smoke": "vitest run",
    "dev": "pnpm --filter @claude-channel-mux/discord run dev",
    "check": "pnpm run lint && pnpm run build && pnpm run typecheck && pnpm run test && pnpm run test:smoke",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "release": "release-it",
    "release:alpha": "release-it --preRelease=alpha"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^20.0.0",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.4",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
