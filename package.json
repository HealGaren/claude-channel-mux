{
  "name": "claude-channel-mux",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "channel-mux": "./dist/cli.mjs",
    "channel-mux-plugin": "./dist/plugin.mjs"
  },
  "scripts": {
    "start": "tsx src/daemon.ts",
    "dev": "tsx --watch src/daemon.ts",
