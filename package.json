    "discord.js": "^14.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
