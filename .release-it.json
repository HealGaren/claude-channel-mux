{
  "git": {
    "commitMessage": "release: v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true
  },
  "npm": {
    "publish": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "hooks": {
    "before:init": ["pnpm run typecheck", "pnpm test"],
    "after:bump": "pnpm run build"
  }
}
